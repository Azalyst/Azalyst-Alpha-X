# Copy this to Railway → Variables tab
# (Never commit actual secrets to GitHub)

# Required: your Discord webhook URL
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Optional: Qwen AI API key (get from dashscope.aliyuncs.com)
# Without this, Qwen will still run but produce placeholder analysis
QWEN_API_KEY=sk-your-qwen-key-here

# Optional: Override Binance endpoint if geo-blocked
# BINANCE_PROXY_URL=https://your-proxy.example.com
